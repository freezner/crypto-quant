# Crypto Quant Simulator - Environment Variables
# 복사 후 .env로 이름 변경: cp .env.example .env

# ============================================
# 시세 조회는 API 키 없이 가능합니다!
# 아래 키들은 추후 실제 거래 기능 추가 시 필요
# ============================================

# Upbit API (https://upbit.com/mypage/open_api_management)
# UPBIT_ACCESS_KEY=your_access_key
# UPBIT_SECRET_KEY=your_secret_key

# Bithumb API (https://apidocs.bithumb.com/)
# BITHUMB_API_KEY=your_api_key
# BITHUMB_SECRET_KEY=your_secret_key

# Coinone API (https://coinone.co.kr/developer/)
# COINONE_ACCESS_TOKEN=your_access_token
# COINONE_SECRET_KEY=your_secret_key

# ============================================
# 데이터베이스 설정
# ============================================

# 로컬 개발 (SQLite) - 기본값, 설정 불필요
# DATABASE_URL=sqlite:///./data/crypto_quant.db

# 프로덕션 (PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/crypto_quant

# ============================================
# 시뮬레이션 설정
# ============================================

# 초기 투자금 (KRW)
INITIAL_BALANCE=10000000

# 시세 수집 주기 (초)
FETCH_INTERVAL=60
